# Copy to .env for local runs. On Railway set these in the dashboard (no file).

PORT=8000

# Tried first by /backend-url when healthy
LOCAL_BACKEND_URL=http://localhost:8080

# Deployed Spring API (Render). Leave empty for local-only.
BACKEND_URL=

# If set, always use this backend (skips health checks)
# FORCE_BACKEND_URL=
