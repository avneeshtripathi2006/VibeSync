# Copy to backend/.env and fill in real values. Never commit backend/.env.

# --- Database (local first, then Supabase fallback) ---
# 1) Local PostgreSQL (tried first when set)
DB_LOCAL_JDBC_URL=jdbc:postgresql://localhost:5432/vibesync_db
DB_LOCAL_USERNAME=postgres
DB_LOCAL_PASSWORD=your_local_postgres_password

# 2) Supabase Postgres (used if local is unreachable). Use JDBC URL from Supabase dashboard (often sslmode=require).
DB_SUPABASE_JDBC_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DB_SUPABASE_USERNAME=postgres
DB_SUPABASE_PASSWORD=your_supabase_db_password

# --- Render / single-URL mode (optional) ---
# If you do NOT set DB_LOCAL_* / DB_SUPABASE_* on the host, set this instead (typical on Render):
# SPRING_DATASOURCE_URL=jdbc:postgresql://...supabase.co:5432/postgres?sslmode=require
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=

# --- Security ---
JWT_SECRET=replace_with_long_random_secret_at_least_32_characters

# --- Public URLs ---
# Browser-facing frontend (OAuth redirect target; include GitHub Pages path if used)
FRONTEND_URL=http://localhost:5173
# OAuth redirect base = backend public origin (no trailing slash)
BACKEND_PUBLIC_URL=http://localhost:8080

# --- CORS / WebSocket ---
WEBSOCKET_ORIGINS=http://localhost:5173
GITHUB_USERNAME=
RENDER_BACKEND_DOMAIN=
CUSTOM_FRONTEND_URL=

# --- OAuth (Google / GitHub / Spotify) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Vibe engine (Railway / local) ---
AI_SERVICE_URL=http://localhost:8000

# --- Optional tuning ---
# JPA_DDL_AUTO=update
# JPA_SHOW_SQL=false
# ACTUATOR_HEALTH_DETAILS=when_authorized
# PORT=8080
