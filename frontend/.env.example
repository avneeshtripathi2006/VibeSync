# Copy to .env.development (local) or rely on GitHub Actions secrets for production builds.
# Never commit real .env.development / .env.production files.

# Public API (required for production CI build)
VITE_API_URL=https://YOUR-BACKEND.onrender.com

# Optional: override default used on *.github.io when VITE_API_URL was missing from an old build
# VITE_PUBLIC_API_FALLBACK=https://YOUR-BACKEND.onrender.com

# WebSocket endpoint (http/https or ws/wss; see src/config/env.js)
VITE_WS_URL=wss://YOUR-BACKEND.onrender.com/ws-vibe

# Auth page probes this first; defaults to http://localhost:8080 if unset
VITE_LOCAL_API_URL=http://localhost:8080

# Axios timeout (ms)
VITE_API_TIMEOUT=45000

# GitHub Pages project site: MUST be /YourRepoName/ (leading and trailing slash). CI defaults to /VibeSync/ if unset.
# VITE_BASE_PATH=/VibeSync/
